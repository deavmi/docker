bots:
  - name: Gitea allow (cloning)
    action: ALLOW
    expression:
      all:
        - 'headers["User-Agent"].startsWith("git")'

  - name: Gitea allow (Go get)
    action: ALLOW
    expression:
      all:
        - 'path.contains("deavmi")'


  - name: Prometheus metrics
    action: ALLOW
    path_regex: .*/metrics
  - name: Challenge all
    user_agent_regex: .*
    action: CHALLENGE

