bots:
  - name: Gitea allow (cloning)
    action: ALLOW
    expression:
      all:
        - 'headers["User-Agent"].startsWith("git")'

  - name: Gitea allow (Go get)
    action: ALLOW
    expression:
      any:
        - '"GoModule" in headers'
        - '"Git-Protocol" in headers'

  - name: Prometheus metrics
    action: ALLOW
    path_regex: .*/metrics
  - name: Challenge all
    user_agent_regex: .*
    action: CHALLENGE

