# Set the configuration file path for Yggdrasil
YGGDRASIL_CONF_PATH=/etc/yggdrasil/yggdrasil.conf

# System information
MY_IPV6=2a04:5b81:2010:a:da3a:ddff:fe8f:48e6
USER_UID=1000
USER_GID=1000
IPV6_POOL_SUBNET=2a04:5b81:2010:b::/64
IPV6_ADDR1=2a04:5b81:2010:b::1
IPV6_ADDR2=2a04:5b81:2010:b::2

# Unbound
UNBOUND_IPV6=${MY_IPV6}
UNBOUND_CTL_DIR=/ctl/unbnd

# Meshnamed
MESHNAMED_LISTEN_ADDR=[::]
MESHNAMED_LISTEN_PORT=1024

# Set the data directory for Mycelium
MYCELIUM_DATA_DIR=/home/deavmi/volumes/mycelium
MYCELIUM_LOG_OPTION=silent
MYCELIUM_PEERS_STRING="tcp://[2a01:4ff:2f0:3621::1]:9651 tcp://[2604:a00:50:17b:9e6b:ff:fe1f:e054]:9651"

# PiHole
PIHOLE_DNS_UPSTREAMS=${UNBOUND_IPV6}#53
PIHOLE_IPV6_ADDR=${IPV6_ADDR2}
PIHOLE_DATA_DIRECTORY=/home/deavmi/volumes/pihole
