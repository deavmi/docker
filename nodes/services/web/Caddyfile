
{
	http_port "80"
	https_port "443"

	log default {
			output stdout
			level DEBUG
	}

  # Don't tell HTTP clients to upgrade to HTTPS
  auto_https disable_redirects
}


# Domain name for automatic SSL
:80, {$DOMAIN}:443 {
	handle / {
		file_server {
			root /landing	
		}
	}

	# Handle metrics
	handle /metrics {
	    metrics
	}
	
	# Forgejo service
	handle /git* {
		uri strip_prefix /git # Straight from https://docs.gitea.com/next/administration/reverse-proxies#caddy-with-a-sub-path
		reverse_proxy gitea:3000
	}

	handle /git_old* {
		uri strip_prefix /git_old
		reverse_proxy gitea_old:3000
	}

	# Minio web console (currently just for Gitea)
	handle /minio* {
		uri strip_prefix /minio
		reverse_proxy minio-gitea:9001
	}
	
	# i2pd console
	handle /i2pd* {
	    reverse_proxy i2pd:7070
	}
	
	# WebIRC
	handle /irc {
        redir /irc* /irc/
	}
	handle /irc/*  {
	    uri strip_prefix /irc
	    reverse_proxy webirc:9000
	}

	# Redirect `/novasredes`
	# to /novasredes/
	handle /novasredes {
		redir /novasredes/
	}
	
	# Match anything matching `/novasredes/*`
	# but remove the `/novasredes/` part
	# and keep whatever the `*` is
	handle_path /novasredes/* {
		# Take `*` and then tack it onto
		# to `/novasredes` so we get
		# `/novasredes/*`
		rewrite /novasredes/{path}
	
		# Set where the path building starts
		#
		# Then request URI is tacked onto this
		# root /
		#
		# We therefore take `/` and make it `//novasredes/{path}`
		root /

		# State we want to serve files
		file_server
	}
}
