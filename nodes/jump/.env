# Global settings (for builds)
USER_UID=1000
USER_GID=1003

# Set the configuration file path for Yggdrasil
YGGDRASIL_CONF_PATH=/mnt/datadisk/volumes/yggdrasil/yggdrasil.conf

# IPv6 subnet for containers that use it
IPV6_POOL_SUBNET=2a04:5b81:2010:300a::/64
IPV6_NODE1_ADDR=2a04:5b81:2010:300a::2

# Yggdrasil subnet for container that use it
YGG_POOL_SUBNET=300:8101:e046:d91e::/64
YGG_NODE1_ADDR=300:8101:e046:d91e::1

# I2P settings
I2PD_CONF_DIR=/mnt/datadisk/volumes/i2pd/conf
I2PD_DATA_DIR=/mnt/datadisk/volumes/i2pd/data
I2PD_KEYS_DIR=/mnt/datadisk/volumes/i2pd/keys
I2PD_IPV6_ADDR=${IPV6_NODE4_ADDR}
I2PD_WEB_DOMAIN=${IPV6_NODE4_DOMAIN}
