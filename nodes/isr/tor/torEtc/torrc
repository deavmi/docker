\# Disallow connecting over IPv4 or else it will consistently
# try to user it and always fail
ClientUseIPv4 0

# Allow usage via IPv6 (default is to not allow it)
ClientUseIPv6 1

# Prometheus logging
MetricsPort [::]:9600
MetricsPortPolicy accept [::]/0

# Pinewood.BNET IRC server
HiddenServiceDir /services/community/irc
HiddenServicePort 6667 ygg.irc.deavmi.assigned.network:6667

# Personal homepage
HiddenServiceDir /services/personal/web
HiddenServicePort 80 ygg.home.deavmi.assigned.network:80
