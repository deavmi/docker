# Global settings (for builds)
USER_UID=1000
USER_GID=1003




# Set the configuration file path for Yggdrasil
YGGDRASIL_CONF_PATH=/mnt/datadisk/volumes/yggdrasil/yggdrasil.conf

# Yggdrasil subnet for container that use it
YGG_POOL_SUBNET=300:2774:d54a:c39e::/64/64
YGG_NODE1_ADDR=300:2774:d54a:c39e::2
YGG_NODE2_ADDR=300:2774:d54a:c39e::3
YGG_NODE3_ADDR=300:2774:d54a:c39e::4


# Caddy domain
CADDY_DOMAIN=monitor.deavmi.assigned.network



# Prometheus
# PROMETHEUS_STATE_DIR=/mnt/datadisk/volumes/prometheus/data

# Grafana
GRAFANA_CONF_DIR=/mnt/datadisk/volumes/grafana/data
GRAFANA_DB_DIR=/mnt/datadisk/volumes/grafana/db

# Alloy
ALLOY_STORAGE=/mnt/datadisk/volumes/alloy/data

# Monitoring agents
AGENT_IRC_PINEWOOD=ygg.services.deavmi.assigned.network:6667
