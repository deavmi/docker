logging {
	level = "debug"
	format = "logfmt"
}

loki.source.syslog "syslog" {
	listener {
		address = "[::]:3333"
		protocol = "udp"
		use_rfc5424_message = true
		label_structured_data = true
	}
	
	forward_to = [loki.write.main.receiver]
}

loki.write "main" {
	endpoint {
		url = "http://loki:3100/loki/api/v1/push"
	}
}
